@model RentaDepartamentosWeb.Models.Departamento
@{
    ViewData["Title"] = "Eliminar Departamento";
}

<!-- Warning header -->
<header class="h-16 flex items-center px-gutter border-b border-error bg-error-container shrink-0 sticky top-0 z-30">
    <div class="max-w-container-max w-full mx-auto flex items-center gap-4">
        <a asp-action="Details" asp-route-id="@Model.Id" class="p-2 rounded-full hover:bg-error/20 text-on-error-container transition-colors">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-on-error-container">warning</span>
            <h2 class="font-headline-md text-headline-md text-on-error-container">Eliminar Departamento</h2>
        </div>
    </div>
</header>

<main class="flex-1 p-gutter">
    <div class="max-w-2xl mx-auto py-8">
        <!-- Alert box -->
        <div class="bg-error-container border border-error rounded-xl p-6 mb-8 flex gap-4 items-start">
            <span class="material-symbols-outlined text-error text-3xl mt-0.5">delete_forever</span>
            <div>
                <h3 class="font-headline-md text-headline-md text-on-error-container mb-2">¿Confirmar eliminación?</h3>
                <p class="font-body-md text-body-md text-on-error-container">
                    Esta acción no se puede deshacer. El departamento y todos sus datos asociados serán eliminados permanentemente del sistema.
                </p>
            </div>
        </div>

        <!-- Property card -->
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl ambient-shadow overflow-hidden mb-8">
            <div class="bg-surface-container p-4 border-b border-outline-variant">
                <span class="font-label-md text-label-md text-on-surface-variant">Propiedad a eliminar</span>
            </div>
            <div class="p-6">
                <div class="flex items-start gap-4 mb-6">
                    <div class="w-14 h-14 rounded-lg bg-surface-container-high flex items-center justify-center text-error shrink-0">
                        <span class="material-symbols-outlined text-3xl">apartment</span>
                    </div>
                    <div>
                        <h4 class="font-headline-md text-headline-md text-on-surface">@Model.Direccion</h4>
                        <p class="font-body-md text-body-md text-on-surface-variant flex items-center gap-1 mt-1">
                            <span class="material-symbols-outlined text-sm">location_on</span>
                            @Model.Colonia, @Model.Ciudad
                        </p>
                    </div>
                </div>

                <div class="grid grid-cols-3 gap-4 py-4 border-y border-outline-variant mb-4">
                    <div class="text-center">
                        <p class="font-label-sm text-label-sm text-on-surface-variant mb-1">Habitaciones</p>
                        <p class="font-headline-md text-headline-md text-on-surface flex items-center justify-center gap-1">
                            <span class="material-symbols-outlined text-sm text-secondary">bed</span> @Model.Habitaciones
                        </p>
                    </div>
                    <div class="text-center">
                        <p class="font-label-sm text-label-sm text-on-surface-variant mb-1">Baños</p>
                        <p class="font-headline-md text-headline-md text-on-surface flex items-center justify-center gap-1">
                            <span class="material-symbols-outlined text-sm text-secondary">shower</span> @Model.Banios
                        </p>
                    </div>
                    <div class="text-center">
                        <p class="font-label-sm text-label-sm text-on-surface-variant mb-1">Precio / Mes</p>
                        <p class="font-headline-md text-headline-md text-on-surface">@Model.PrecioRenta.ToString("C0")</p>
                    </div>
                </div>

                <div class="flex items-center justify-between">
                    <span class="font-label-md text-label-md text-on-surface-variant">Estado actual</span>
                    @if (Model.Estado == "Disponible")
                    {
                        <span class="bg-tertiary-container text-on-tertiary-container font-label-sm text-label-sm px-3 py-1 rounded-full">Disponible</span>
                    }
                    else if (Model.Estado == "Rentado")
                    {
                        <span class="bg-error-container text-on-error-container font-label-sm text-label-sm px-3 py-1 rounded-full border border-error">Rentado</span>
                    }
                    else
                    {
                        <span class="bg-surface-variant text-on-surface-variant font-label-sm text-label-sm px-3 py-1 rounded-full">Mantenimiento</span>
                    }
                </div>

                @if (Model.Estado == "Rentado")
                {
                    <div class="mt-4 p-3 bg-error-container rounded-lg border border-error">
                        <p class="font-label-md text-label-md text-on-error-container flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm">person</span>
                            Arrendatario: <strong>@Model.Arrendatario</strong>
                        </p>
                    </div>
                }
            </div>
        </div>

        <!-- Action buttons -->
        <div class="flex flex-col sm:flex-row gap-3 justify-end">
            <a asp-action="Details" asp-route-id="@Model.Id"
               class="flex-1 sm:flex-none px-6 py-3 rounded-lg border border-outline-variant text-on-surface font-label-md text-label-md text-center hover:bg-surface-container-low transition-colors flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-sm">arrow_back</span> Cancelar
            </a>
            <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post" class="flex-1 sm:flex-none">
                @Html.AntiForgeryToken()
                <button type="submit"
                        class="w-full px-6 py-3 rounded-lg bg-error text-on-error font-label-md text-label-md hover:opacity-90 transition-opacity ambient-shadow flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-sm">delete_forever</span> Sí, Eliminar
                </button>
            </form>
        </div>
    </div>
</main>
