@{
    ViewData["Title"] = "Reportes";
    var departamentos = ViewBag.Departamentos as List<RentaDepartamentosWeb.Models.Departamento> ?? new();
    decimal totalIngresos = ViewBag.TotalIngresos ?? 0m;
    int totalDeps = departamentos.Count;
    int rentados = departamentos.Count(d => d.Estado == "Rentado");
    int disponibles = departamentos.Count(d => d.Estado == "Disponible");
    int mantenimiento = departamentos.Count(d => d.Estado == "Mantenimiento");
    double tasa = totalDeps > 0 ? Math.Round((double)rentados / totalDeps * 100, 1) : 0;
}

<header class="bg-surface-container-lowest border-b border-outline-variant sticky top-0 z-30">
    <div class="flex items-center justify-between px-gutter h-16 max-w-container-max mx-auto">
        <h1 class="font-headline-md text-headline-md text-on-surface">Reportes de Rendimiento</h1>
        <span class="font-label-sm text-label-sm text-on-surface-variant">Generado: @DateTime.Now.ToString("dd/MM/yyyy")</span>
    </div>
</header>

<main class="flex-1 p-gutter max-w-container-max mx-auto w-full">

    <!-- KPIs -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-5 ambient-shadow">
            <p class="font-label-sm text-label-sm text-on-surface-variant mb-2">Total Propiedades</p>
            <p class="font-headline-xl text-headline-xl text-on-surface">@totalDeps</p>
        </div>
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-5 ambient-shadow">
            <p class="font-label-sm text-label-sm text-on-surface-variant mb-2">Tasa Ocupación</p>
            <p class="font-headline-xl text-headline-xl text-tertiary">@tasa%</p>
        </div>
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-5 ambient-shadow">
            <p class="font-label-sm text-label-sm text-on-surface-variant mb-2">Ingresos / Mes</p>
            <p class="font-headline-xl text-headline-xl text-primary">@totalIngresos.ToString("C0")</p>
        </div>
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-5 ambient-shadow">
            <p class="font-label-sm text-label-sm text-on-surface-variant mb-2">En Mantenimiento</p>
            <p class="font-headline-xl text-headline-xl text-error">@mantenimiento</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
        <!-- Distribution chart -->
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl ambient-shadow p-6">
            <h2 class="font-headline-md text-headline-md text-on-surface mb-6 pb-2 border-b border-outline-variant">
                Distribución por Estado
            </h2>
            <div class="space-y-5">
                <!-- Disponible -->
                <div>
                    <div class="flex justify-between font-label-md text-label-md mb-1">
                        <span class="text-on-surface">Disponibles</span>
                        <span class="text-tertiary font-medium">@disponibles (@(totalDeps > 0 ? Math.Round((double)disponibles / totalDeps * 100) : 0)%)</span>
                    </div>
                    <div class="h-3 bg-surface-container-high rounded-full overflow-hidden">
                        <div class="h-full bg-tertiary rounded-full transition-all duration-500"
                             style="width:@(totalDeps > 0 ? (double)disponibles / totalDeps * 100 : 0)%"></div>
                    </div>
                </div>
                <!-- Rentado -->
                <div>
                    <div class="flex justify-between font-label-md text-label-md mb-1">
                        <span class="text-on-surface">Rentados</span>
                        <span class="text-error font-medium">@rentados (@(totalDeps > 0 ? Math.Round((double)rentados / totalDeps * 100) : 0)%)</span>
                    </div>
                    <div class="h-3 bg-surface-container-high rounded-full overflow-hidden">
                        <div class="h-full bg-error rounded-full transition-all duration-500"
                             style="width:@(totalDeps > 0 ? (double)rentados / totalDeps * 100 : 0)%"></div>
                    </div>
                </div>
                <!-- Mantenimiento -->
                <div>
                    <div class="flex justify-between font-label-md text-label-md mb-1">
                        <span class="text-on-surface">Mantenimiento</span>
                        <span class="text-on-surface-variant font-medium">@mantenimiento (@(totalDeps > 0 ? Math.Round((double)mantenimiento / totalDeps * 100) : 0)%)</span>
                    </div>
                    <div class="h-3 bg-surface-container-high rounded-full overflow-hidden">
                        <div class="h-full bg-outline-variant rounded-full transition-all duration-500"
                             style="width:@(totalDeps > 0 ? (double)mantenimiento / totalDeps * 100 : 0)%"></div>
                    </div>
                </div>
            </div>

            <!-- Legend -->
            <div class="flex gap-6 mt-6 pt-4 border-t border-outline-variant">
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-tertiary inline-block"></span>
                    <span class="font-label-sm text-label-sm text-on-surface-variant">Disponible</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-error inline-block"></span>
                    <span class="font-label-sm text-label-sm text-on-surface-variant">Rentado</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-outline-variant inline-block"></span>
                    <span class="font-label-sm text-label-sm text-on-surface-variant">Mantenimiento</span>
                </div>
            </div>
        </div>

        <!-- Income by city (bar chart) -->
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl ambient-shadow p-6">
            <h2 class="font-headline-md text-headline-md text-on-surface mb-6 pb-2 border-b border-outline-variant">
                Ingresos por Departamento
            </h2>
            @{
                var rentadosList = departamentos.Where(d => d.Estado == "Rentado").OrderByDescending(d => d.PrecioRenta).ToList();
                var maxPrecio = rentadosList.Count > 0 ? rentadosList.Max(d => d.PrecioRenta) : 1m;
            }
            @if (rentadosList.Count == 0)
            {
                <div class="flex flex-col items-center justify-center h-40 text-on-surface-variant font-body-md text-body-md">
                    <span class="material-symbols-outlined text-4xl mb-2 text-outline">bar_chart</span>
                    Sin departamentos rentados actualmente.
                </div>
            }
            else
            {
                <div class="space-y-3">
                    @foreach (var dep in rentadosList.Take(6))
                    {
                        var pct = maxPrecio > 0 ? (double)dep.PrecioRenta / (double)maxPrecio * 100 : 0;
                        <div>
                            <div class="flex justify-between font-label-sm text-label-sm mb-1">
                                <span class="text-on-surface truncate max-w-[60%]">@dep.Direccion</span>
                                <span class="text-primary font-medium">@dep.PrecioRenta.ToString("C0")</span>
                            </div>
                            <div class="h-2.5 bg-surface-container-high rounded-full overflow-hidden">
                                <div class="h-full bg-primary rounded-full" style="width:@pct%"></div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Department detail table -->
    <div class="bg-surface-container-lowest border border-outline-variant rounded-xl ambient-shadow overflow-hidden">
        <div class="p-4 border-b border-outline-variant bg-surface-container-low">
            <h2 class="font-headline-md text-headline-md text-on-surface">Detalle por Propiedad</h2>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-container border-b border-outline-variant text-on-surface-variant font-label-md text-label-md uppercase tracking-wider">
                        <th class="p-4 font-semibold">Propiedad</th>
                        <th class="p-4 font-semibold">Ciudad</th>
                        <th class="p-4 font-semibold text-center">Estado</th>
                        <th class="p-4 font-semibold text-right">Precio/Mes</th>
                        <th class="p-4 font-semibold">Arrendatario</th>
                    </tr>
                </thead>
                <tbody class="font-body-md text-body-md divide-y divide-outline-variant">
                    @foreach (var dep in departamentos)
                    {
                        <tr class="hover:bg-surface-container-low transition-colors">
                            <td class="p-4">
                                <a asp-action="Details" asp-route-id="@dep.Id" class="text-primary hover:underline font-medium">
                                    @dep.Direccion
                                </a>
                                <div class="font-label-sm text-label-sm text-secondary">@dep.Colonia</div>
                            </td>
                            <td class="p-4 text-on-surface-variant">@dep.Ciudad</td>
                            <td class="p-4 text-center">
                                @if (dep.Estado == "Disponible")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full font-label-sm text-label-sm bg-tertiary-container text-on-tertiary-container">Disponible</span>
                                }
                                else if (dep.Estado == "Rentado")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full font-label-sm text-label-sm bg-error-container text-on-error-container">Rentado</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full font-label-sm text-label-sm bg-surface-variant text-on-surface-variant">Mantenimiento</span>
                                }
                            </td>
                            <td class="p-4 text-right font-medium @(dep.Estado == "Rentado" ? "text-on-surface" : "text-on-surface-variant")">
                                @(dep.Estado == "Rentado" ? dep.PrecioRenta.ToString("C0") : "—")
                            </td>
                            <td class="p-4 text-on-surface-variant">@(dep.Arrendatario ?? "—")</td>
                        </tr>
                    }
                    @if (!departamentos.Any())
                    {
                        <tr>
                            <td colspan="5" class="p-12 text-center text-on-surface-variant font-body-md text-body-md">
                                No hay departamentos registrados.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</main>
